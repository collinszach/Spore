# Secrets
.env
*.env
!.env.example
**/secrets/**
*.p8

# Python
**/__pycache__/**
*.pyc
.venv/
venv/
.pytest_cache/

# iOS / Xcode
ios/build/**
*.ipa
*.xcuserstate
