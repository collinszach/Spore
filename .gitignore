# Secrets
.env
*.env
!.env.example
**/secrets/**
*.p8

# Python
**/__pycache__/**
*.pyc
.venv/
venv/
.pytest_cache/

# iOS / Xcode
ios/build/**
*.ipa
*.xcuserstate
DerivedData/
# generated by `xcodegen generate` from ios/project.yml
ios/Spore.xcodeproj/

# Vault (Obsidian) — submodule. Dev sandbox scratch (incl. its nested git repo)
# is never versioned in the app repo; keep only the placeholder dir.
vault/*
!vault/_sandbox/
vault/_sandbox/*
!vault/_sandbox/.gitkeep

# Uploaded media (voice capture audio) — host volume, not versioned
media/

# Misc
.DS_Store
files.zip
